# .env file for Sniper Bot
# Βάλε το private key από το Burner Wallet σου (Σε μορφή Base58 - το κλασικό format του Phantom/Solflare)
PRIVATE_KEY="YOUR_WALLET_PRIVATE_KEY_HERE"

# 2. Αντικατέστησε τα παρακάτω URLs με αυτά που σου έδωσε το Helius
RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE"
WSS_URL="wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE"

# 3. Βάλε έναν κωδικό πρόσβασης (Password) για να κλειδώσεις το Web UI
ADMIN_PASSWORD="my_super_secret_password"
