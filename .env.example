# .env file for Sniper Bot
# Βάλε το private key από το Burner Wallet σου (Σε μορφή Base58 - το κλασικό format του Phantom/Solflare)
PRIVATE_KEY="YOUR_WALLET_PRIVATE_KEY_HERE"

# Δωρεάν Public RPC (Μπορείς να χρησιμοποιήσεις το mainnet-beta ή να βάλεις ένα δωρεάν Helius/QuickNode URL)
RPC_URL="https://api.mainnet-beta.solana.com"
WSS_URL="wss://api.mainnet-beta.solana.com"
